exports[`detectors page snapshot 1`] = `
<DocumentFragment>
  <main>
    <h2>
      Detectors
    </h2>
    <form
      class="panel"
    >
      <h3>
        Create detector
      </h3>
      <div
        class="form-grid"
      >
        <label>
          Detector name
          <input
            minlength="3"
            required=""
            value="Default detector"
          />
        </label>
        <label>
          Status
          <select>
            <option
              value="draft"
            >
              Draft
            </option>
            <option
              value="active"
            >
              Active
            </option>
            <option
              value="archived"
            >
              Archived
            </option>
          </select>
        </label>
        <label>
          Description
          <input
            maxlength="180"
            required=""
            value="Detects traffic spikes in rolling windows"
          />
        </label>
        <label>
          Sensitivity (0.1 - 1.0)
          <input
            max="1"
            min="0.1"
            required=""
            step="0.05"
            type="number"
            value="0.7"
          />
        </label>
        <label>
          Window size (seconds)
          <input
            max="3600"
            min="10"
            required=""
            step="10"
            type="number"
            value="60"
          />
        </label>
        <label>
          Window step (seconds)
          <input
            max="900"
            min="5"
            required=""
            step="5"
            type="number"
            value="30"
          />
        </label>
        <label>
          Features (comma-separated)
          <input
            placeholder="bytes_per_sec, packets_per_sec, latency_ms"
            required=""
            value="bytes_per_sec, packets_per_sec"
          />
        </label>
      </div>
      <div
        style="margin-top: 12px;"
      >
        <button
          class="primary"
          type="submit"
        >
          Save detector
        </button>
      </div>
    </form>
    <section
      class="panel"
    >
      <h3>
        Configured detectors
      </h3>
      <ul>
        <li>
          <strong>
            Detector A
          </strong>
           (active) 
          <span
            class="small"
          >
            sensitivity: -, window: -s / -s, features: -
          </span>
           
          <button
            type="button"
          >
            Archive
          </button>
        </li>
      </ul>
    </section>
  </main>
</DocumentFragment>
`;

